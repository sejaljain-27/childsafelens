<?xml version="1.0" encoding="utf-8"?>
<!--
  Scoped to our OWN demo app for this sprint (per plan Section 1: "one
  target surface only"). To expand to a real chat app later, add its
  package name to android:packageNames as a comma-separated list, e.g.
  "com.childsafelens.demo,com.whatsapp"
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeViewTextChanged|typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:notificationTimeout="100"
    android:canRetrieveWindowContent="true"
    android:packageNames="com.childsafelens.demo" />
